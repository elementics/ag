{
  "name": "@elementics/ag",
  "version": "4.5.8",
  "description": "Persistent AI coding agent with memory - any model via OpenRouter",
  "type": "module",
  "bin": {
    "ag": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "npm run build && node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run type-check && npm run test && tsc"
  },
  "keywords": [
    "agent",
    "ai",
    "typescript",
    "memory-palace",
    "cli",
    "openrouter"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "typescript": "^6.0.0",
    "vitest": "^4.1.4"
  }
}
